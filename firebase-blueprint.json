{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "User messages"
    }
  }
}
